# =============================================================================
# Sluiskade · environment variables
# =============================================================================
# Copy this file to .env for local development (never commit .env).
# In production, set these in the Coolify dashboard under Environment Variables.
# =============================================================================

# --- Flask -------------------------------------------------------------------
# Used to sign session cookies. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-long-random-hex-string

# --- Sluiswachter QR token ---------------------------------------------------
# HMAC secret used to sign the QR token. Generate the same way as SECRET_KEY.
# Rotate by generating a new value AND bumping QR_TOKEN_VERSION below.
QR_TOKEN_SECRET=replace-me-with-a-different-long-random-hex-string

# Bump this integer to invalidate all existing QR codes at once.
QR_TOKEN_VERSION=1

# --- Resend (transactional email) --------------------------------------------
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_dummy_key_replace_in_coolify

# From address for magic-link and notification emails.
# The domain must be verified in Resend with DKIM/SPF records in Cloudflare.
# Use a real, monitored inbox (not noreply@) so people can actually reply
# if something is wrong · it builds trust and dodges spam-filter penalties.
MAIL_FROM=Sluiskade <beheer@sluiskade.com>

# --- Authentik (admin SSO via OIDC) ------------------------------------------
OIDC_CLIENT_ID=replace-in-coolify
OIDC_CLIENT_SECRET=replace-in-coolify
OIDC_DISCOVERY_URL=https://auth.droog.cloud/application/o/sluiskade/.well-known/openid-configuration

# --- Admin contact -----------------------------------------------------------
# Receives access-request notifications and storage-quota warnings.
ADMIN_EMAIL=beheer@sluiskade.com

# --- Storage & quotas --------------------------------------------------------
# Hard cap on the photo directory size, in gigabytes. Uploads beyond this are refused.
STORAGE_QUOTA_GB=20

# Path inside the container where photos and SQLite live. Mounted as a Coolify volume.
DATA_PATH=/data

# --- Gamification ------------------------------------------------------------
# Total number of photos that completes the shared goal.
GOAL_TOTAL=1000
